# Standard Python Ignores
# Compiled python files
__pycache__/
*.pyc
*.pyd
*.pyo

# Environments
.env
.venv/
env/
venv/

# IDE and OS files
.DS_Store
Thumbs.db
.idea/
.vscode/

# Datasets and Generated Data
# Ignore the entire data directory and its contents
data/
datasets/
inputs/
input/

# Ignore specific large file formats anywhere in the repo
*.nc
*.grib
*.csv
*.tsv
*.parquet
*.sqlite
